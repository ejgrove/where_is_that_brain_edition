{
  "name": "where-is-this-brain",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "serve:web": "./.conda-env/bin/python -m http.server 4173 --bind 0.0.0.0 --directory dist",
    "preview:web": "npm run export:web && ./.conda-env/bin/python -m http.server 4173 --bind 0.0.0.0 --directory dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "expo": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^57.0.2",
    "typescript": "~5.9.2"
  }
}
